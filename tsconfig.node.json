{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "module": "nodenext",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "files": [
    "vite.config.ts",
    "scripts/content/generate-images.ts",
    "scripts/content/test-content-clients.ts",
    "scripts/content/test-content-http.ts",
    "scripts/content/test-image-pipeline.ts",
    "scripts/content/test-local-acceptance.ts",
    "scripts/content/test-performance-budget.ts",
    "scripts/content/test-static-artifact.ts",
    "scripts/content/validate-content.ts",
    "scripts/serve-static.ts"
  ]
}
